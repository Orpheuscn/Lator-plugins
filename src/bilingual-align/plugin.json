        },
        {
          "sourcePath": "tokenizer_config.json",
          "targetPath": "tokenizer_config.json",
          "required": true
        },
        {
          "sourcePath": "vocab.txt",
          "targetPath": "vocab.txt",
          "required": true
        },
        {
          "sourcePath": "config.json",
          "targetPath": "config.json"
        },
        {
          "sourcePath": "special_tokens_map.json",
          "targetPath": "special_tokens_map.json"
        }
      ],
      "requiredFiles": [
        "model.onnx",
        "tokenizer.json",
        "tokenizer_config.json",
        "vocab.txt"
      ]
    }
  ],
  "capabilities": [
