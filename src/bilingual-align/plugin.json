      "mirrorSources": [
        {
          "id": "hf-mirror",
          "label": {
            "zh-CN": "国内镜像",
            "en-US": "HF Mirror"
          },
          "baseUrl": "https://hf-mirror.com/sentence-transformers/LaBSE/resolve/ac91d6745aefb758c373ef4d37a13ff5e04ad876"
        }
      ],
      "repo": "sentence-transformers/LaBSE",
      "revision": "ac91d6745aefb758c373ef4d37a13ff5e04ad876",
      "files": [
        {
          "sourcePath": "onnx/model.onnx",
          "targetPath": "model.onnx",
