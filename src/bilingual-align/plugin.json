{
  "schemaVersion": 1,
  "id": "lator.bilingual-align",
  "version": "0.1.0",
  "label": "Bilingual Align",
  "localizedLabel": {
    "zh-CN": "双语对齐",
    "en-US": "Bilingual Align"
